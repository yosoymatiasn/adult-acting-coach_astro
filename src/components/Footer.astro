---
import Image from 'astro/components/Image.astro'
import logo from '../assets/images/logo.png'
import { navLinks } from '../data/nav'

const footerNav = navLinks.filter(({ href }) =>
  ['/about', '/classes', '/building-your-brand', '/self-tapes'].includes(href)
)

const socialLinks = [
  {
    href: 'https://www.instagram.com/sararogersacting/?hl=en',
    label: 'Instagram',
    shortLabel: 'IG',
  },
  {
    href: 'https://www.facebook.com/sara.rogers.568',
    label: 'Facebook',
    shortLabel: 'f',
  },
  {
    href: 'https://www.meetup.com/South-Florida-Actors/',
    label: 'Meetup',
    shortLabel: 'Meetup',
  },
]

interface Props {
  spacious?: boolean
  bordered?: boolean
}

const { spacious = true, bordered = true } = Astro.props

const footerClasses = [
  spacious ? 'mt-14 md:mt-20' : '',
  bordered ? 'border-t border-purple/20' : '',
  'bg-gray-50 px-4 py-12',
]
---

<footer class:list={footerClasses}>
  <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
    <div>
      <div class="flex items-center gap-4">
        <span
          class="flex h-16 w-16 items-center justify-center rounded-full border border-purple/15 bg-white"
        >
          <Image
            src={logo}
            alt=""
            width={76}
            height={76}
            class="h-14 w-14 object-contain"
          />
        </span>
        <p class="text-3xl font-bold text-purple">Sara Rogers</p>
      </div>
      <p class="mt-3 max-w-md text-lg leading-8 text-gray-700">
        Adult acting, improv, and public speaking coaching in South Florida.
      </p>
    </div>

    <nav aria-label="Footer navigation">
      <p class="text-sm font-semibold uppercase tracking-wide text-purple">
        Explore
      </p>
      <div class="mt-4 flex flex-col gap-3 text-lg font-semibold text-gray-800">
        {
          footerNav.map((link) => (
            <a href={link.href} class="transition hover:text-purple">
              {link.label}
            </a>
          ))
        }
      </div>
    </nav>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-purple">
        Connect
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="flex h-12 min-w-12 items-center justify-center rounded-full border border-purple/20 bg-white px-4 text-base font-bold text-purple transition hover:-translate-y-0.5 hover:border-purple hover:bg-purple hover:text-white hover:shadow-md"
            >
              {link.shortLabel}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="mx-auto mt-10 max-w-6xl border-t border-gray-200 pt-6 text-sm text-gray-600"
  >
    <div>
      &copy; {new Date().getFullYear()} Sara Rogers. All rights reserved.
    </div>
    <div class="mt-2 text-gray-500">
      Website built by
      <a
        href="mailto:howsmatias@gmail.com?subject=Website%20Inquiry"
        class="font-semibold text-purple transition hover:text-purple/80"
      >
        Matias Agnese
      </a>
    </div>
  </div>
</footer>
