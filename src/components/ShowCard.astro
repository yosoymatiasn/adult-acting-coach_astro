---
import type { TShowcaseListing } from '../data/showcases'
import Image from 'astro/components/Image.astro'
import { formatDate, formatTimeRange } from '../helpers/listingHelpers'

const { showData } = Astro.props as { showData: TShowcaseListing }

const { date } = formatDate(showData.date)
const timeRange = formatTimeRange(showData.date, showData.endDate)
---

<div
  class="relative flex h-full w-full flex-col overflow-hidden rounded-md border shadow-md"
>
  <a
    href={showData.url}
    target="_blank"
    rel="noopener noreferrer"
    class="relative block"
  >
    <div class="group overflow-hidden h-60 relative">
      <div
        class="transition-colors absolute inset-0 bg-black/40 group-hover:bg-black/0 pointer-events-none z-10"
      >
      </div>
      <Image
        src={showData.imageUrl}
        alt={showData.title}
        width={800}
        height={400}
        class="transition-transform w-full h-full object-cover object-top scale-105 group-hover:scale-100"
      />
    </div>
  </a>

  <div class="flex flex-1 flex-col p-2 md:px-6 md:py-4">
    <a href={showData.url} target="_blank" rel="noopener noreferrer">
      <h2 class="mb-1 min-h-[4.5rem] text-3xl leading-tight">
        {showData.title}
      </h2>
    </a>

    <div class="mt-2 text-sm font-medium text-gray-600">
      <p>
        <span class="font-semibold text-gray-800">{date}</span>
        <span class="mx-2 text-gray-400">•</span>
        <span class="font-semibold text-gray-800">{timeRange}</span>
      </p>
    </div>

    <p class="mt-3 text-base line-clamp-3 text-gray-700">
      {showData.description}
    </p>

    <div
      class="mt-auto flex items-center justify-between gap-4 border-t border-gray-200 pt-4"
    >
      <div>
        <p class="text-xs uppercase tracking-wide text-gray-500">Admission</p>
        <p class="text-2xl font-semibold text-gray-900">
          {showData.price ? `$${showData.price}` : 'Free'}
        </p>
      </div>

      <a
        href={showData.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-md bg-red-400 px-8 py-3 text-center font-semibold text-white shadow-md transition-colors duration-200 hover:bg-purple"
      >
        RSVP
      </a>
    </div>
  </div>
</div>
