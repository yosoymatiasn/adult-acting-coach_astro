---
// Banner.astro
interface Props {
  title?: string
}

const { title } = Astro.props
---

<section
  class="mb-10 overflow-hidden bg-gradient-to-br from-purple via-purple-light to-purple text-white md:mb-14"
>
  <div
    class="container mx-auto flex flex-col items-center px-4 pb-12 pt-28 text-center md:pb-16 md:pt-36"
  >
    <p class="text-sm font-semibold uppercase tracking-wide text-white/75">
      Sara Rogers Acting
    </p>
    <h1 class="mt-2 text-4xl leading-tight text-white md:text-5xl">
      {title}
    </h1>
  </div>
</section>
