---
import type { TClassListing } from '../data/classes'
import Image from 'astro/components/Image.astro'
import { formatDate } from '../helpers/listingHelpers'

const { classData } = Astro.props as { classData: TClassListing }

const { date } = formatDate(classData.date)
const weekday = new Date(classData.date).toLocaleDateString('en-US', {
  weekday: 'long',
})
---

<div
  data-class-card
  data-class-title={classData.title}
  data-class-slug={classData.slug}
  data-class-date={classData.date}
  data-class-url={classData.url}
  data-class-day-of-week={classData.dayOfWeek}
  data-class-type={classData.type}
  data-class-price={classData.price}
  class="w-full border relative rounded-md overflow-hidden shadow-md"
>
  <a
    href={`/classes/${classData.slug}`}
    rel="noopener noreferrer"
    class="class-link relative"
  >
    <div class="group overflow-hidden h-60 relative">
      <div
        class="transition-colors absolute inset-0 bg-black/50 group-hover:bg-black/0 pointer-events-none z-10"
      >
      </div>
      <Image
        data-class-image
        src={classData.imageUrl}
        alt={classData.title}
        width={800}
        height={400}
        class="transition-transform w-full h-full object-cover object-top group-hover:scale-100 scale-110"
      />
    </div>
  </a>

  <div class="p-2 md:px-6 md:py-4">
    <a
      href={classData.imageUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="class-link"
    >
      <h2 class="text-3xl inline-block mb-1">{classData.title}</h2>
    </a>
    <div class="mt-2 text-sm font-medium text-gray-600 space-y-1">
      {
        classData.type === 'class' ? (
          <>
            <p>
              <span class="font-semibold text-gray-800">{weekday}s</span>
              <span class="mx-2 text-gray-400">•</span>
              <span class="font-semibold text-gray-800">6:30–9:30 PM</span>
            </p>
          </>
        ) : (
          <p>
            <span class="font-semibold text-gray-800">{weekday}</span>
            <span class="mx-2 text-gray-400">•</span>
            <span class="font-semibold text-gray-800">12–3 PM</span>
          </p>
        )
      }
      {
        classData.type === 'class' ? (
          <p>Starts {date.replace(/^[A-Za-z]{3},\s/, '')} </p>
        ) : (
          <p>{date.replace(/^[A-Za-z]{3},\s/, '')}</p>
        )
      }
    </div>
    <p class="mt-3 text-base line-clamp-3 text-gray-700">
      {classData.description}
    </p>

    <div
      class="mt-5 flex gap-2 items-center justify-center border-t border-gray-200 pt-4"
    >
      <div class="mr-auto">
        <p class="text-xs uppercase tracking-wide text-gray-500">Price</p>
        <p class="text-2xl font-semibold text-gray-900">${classData.price}</p>
      </div>
      <button
        type="button"
        data-register-button
        class="inline-block bg-red-400 hover:bg-purple text-white font-semibold rounded-md py-3 px-12 text-center shadow-md transition-colors duration-200 cursor-pointer"
      >
        Register
      </button>

      <a
        href={`/classes/${classData.slug}`}
        rel="noopener noreferrer"
        class="inline-block text-sm border border-purple text-purple hover:underline rounded-md py-2 px-6 text-center transition-all duration-200"
      >
        More details
      </a>
    </div>
  </div>
</div>

<script>
  const cards = document.querySelectorAll('[data-class-card]')

  cards.forEach((card) => {
    const image = card.querySelector('[data-class-image]')
    const links = card.querySelectorAll('.class-link')
    const registerButton = card.querySelector('[data-register-button]')

    links.forEach((link) => {
      link.addEventListener('mouseenter', () => {
        image?.classList.add('scale-100')
        image?.classList.remove('scale-110')
      })
      link.addEventListener('mouseleave', () => {
        image?.classList.add('scale-110')
        image?.classList.remove('scale-100')
      })
    })

    registerButton?.addEventListener('click', () => {
      window.dispatchEvent(
        new CustomEvent('open-class-modal', {
          detail: {
            title: card.getAttribute('data-class-title'),
            slug: card.getAttribute('data-class-slug'),
            type: card.getAttribute('data-class-type'),
            dayOfWeek: card.getAttribute('data-class-day-of-week'),
            date: card.getAttribute('data-class-date'),
            url: card.getAttribute('data-class-url'),
            price: Number(card.getAttribute('data-class-price')),
          },
        })
      )
    })
  })
</script>
