<dialog
  id="classRegistrationModal"
  aria-labelledby="modal-title"
  class="fixed inset-0 size-auto max-h-none max-w-none overflow-y-auto bg-gray-300/75"
>
  <div
    data-modal-backdrop
    tabindex="0"
    class="flex min-h-full items-end justify-center p-4 text-center focus:outline-none sm:items-center sm:p-0"
  >
    <div
      class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg"
    >
      <form
        data-netlify="true"
        name="registration"
        method="POST"
        netlify-honeypot="bot-field"
        id="registration-form"
      >
        <input type="hidden" name="form-name" value="registration" />

        <p class="hidden">
          <label>
            Don’t fill this out if you’re human:
            <input name="bot-field" type="text" />
          </label>
        </p>

        <input type="hidden" name="classTitle" id="form-class-title" />
        <input type="hidden" name="classSession" id="form-session-details" />
        <input type="hidden" name="paymentNote" id="form-payment-note" />

        <div class="px-6 py-6 sm:p-8">
          <div
            id="class-summary"
            class="rounded-lg border border-gray-200 bg-gray-50 p-4"
          >
            <p
              class="text-xs font-semibold uppercase tracking-wide text-gray-500"
            >
              Registering for
            </p>

            <h2
              id="modal-title"
              class="mt-2 text-2xl font-semibold text-gray-900"
            >
              <span id="summary-title"></span>
            </h2>

            <div class="mt-3 flex flex-col gap-1 text-sm text-gray-700">
              <p id="summary-date" class="font-medium"></p>

              <p>
                Price: <span
                  id="summary-price"
                  class="font-semibold text-gray-900"></span>
              </p>
            </div>
          </div>

          <div id="student-fields" class="mt-6 space-y-4">
            <div>
              <label
                for="student-name"
                class="block text-sm font-semibold text-gray-900"
              >
                Full name
              </label>
              <input
                id="student-name"
                name="studentName"
                type="text"
                required
                class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-purple focus:outline-none"
              />
            </div>

            <div>
              <label
                for="student-email"
                class="block text-sm font-semibold text-gray-900"
              >
                Email
              </label>
              <input
                id="student-email"
                name="studentEmail"
                type="email"
                required
                class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-purple focus:outline-none"
              />
            </div>

            <div>
              <label
                for="student-phone"
                class="block text-sm font-semibold text-gray-900"
              >
                Phone
              </label>
              <input
                id="student-phone"
                name="studentPhone"
                type="tel"
                required
                class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-purple focus:outline-none"
              />
            </div>
          </div>

          <div id="payment-section" class="mt-6">
            <p
              id="payment-section-heading"
              class="text-sm font-semibold text-gray-900"
            >
              Payment method
            </p>

            <div class="mt-3 space-y-3">
              <label
                id="zelle-option"
                class="flex cursor-pointer gap-3 rounded-lg border border-purple/20 bg-purple/5 p-4"
              >
                <input
                  type="radio"
                  data-payment-method="Zelle"
                  value="Zelle"
                  checked
                  class="mt-1"
                />
                <span>
                  <span class="block text-sm font-semibold text-gray-900">
                    Zelle (preferred)
                  </span>
                  <span class="mt-1 block text-sm text-gray-700">
                    Send payment to <strong>sararogers147@gmail.com</strong>.
                  </span>
                  <span class="mt-2 block text-xs text-gray-600">
                    Include memo: <span
                      id="zelle-memo-preview"
                      class="font-semibold"></span>
                  </span>
                </span>
              </label>

              <label
                id="paypal-option"
                class="flex cursor-pointer gap-3 rounded-lg border border-gray-200 bg-white p-4"
              >
                <input
                  type="radio"
                  data-payment-method="PayPal / Card"
                  value="PayPal / Card"
                  class="mt-1"
                />
                <span>
                  <span class="block text-sm font-semibold text-gray-900">
                    PayPal (account needed)
                  </span>
                  <span class="mt-1 block text-sm text-gray-700">
                    Pay with your PayPal account using your PayPal balance,
                    linked bank account, or credit/debit card.
                  </span>
                  <span class="mt-2 block text-xs text-gray-600">
                    Include memo: <span
                      id="paypal-memo-preview"
                      class="font-semibold"></span>
                  </span>

                  <a
                    id="paypal-link"
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-3 inline-flex items-center text-sm font-semibold text-purple hover:underline"
                  >
                    Open Paypal payment →
                  </a>
                </span>
              </label>
            </div>
          </div>

          <p
            id="registration-note"
            class="mt-6 text-xs text-gray-600 text-center"
          >
            Your registration is submitted when you send this form. Your spot is
            only confirmed once payment has been received.
          </p>

          <p id="registration-status" class="mt-4 hidden text-sm text-center">
          </p>

          <div
            id="success-panel"
            class="mt-6 hidden rounded-lg border border-purple/20 bg-purple/5 p-4 text-sm text-gray-700"
          >
            <h3 class="text-lg font-semibold text-gray-900">
              Registration received
            </h3>

            <p
              id="success-class"
              class="mt-3 text-base font-semibold text-gray-900"
            >
            </p>
            <p id="success-session" class="mt-1 text-base"></p>

            <div class="mt-4 border-t border-purple/20 pt-4">
              <p class="text-sm font-semibold text-gray-900">Next steps</p>
              <ol class="mt-3 space-y-3 text-sm text-gray-700">
                <li>
                  <span class="font-semibold text-gray-900">1.</span>
                  Your registration details were submitted.
                </li>
                <li>
                  <span class="font-semibold text-gray-900">2.</span>
                  <span id="success-payment-instructions"></span>
                  <span
                    id="success-payment-memo"
                    class="mt-1 block font-semibold text-gray-900"></span>
                  <a
                    id="success-paypal-link"
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-2 hidden font-semibold text-purple hover:underline"
                  >
                    Open PayPal payment →
                  </a>
                </li>
                <li>
                  <span class="font-semibold text-gray-900">3.</span>
                  You'll receive a confirmation email once payment has been received.
                  If you don't receive confirmation within 24 hours, please contact
                  us.
                </li>
              </ol>
            </div>

            <div class="mt-4 rounded-md border border-blue-200 bg-blue-50 p-3">
              <p class="text-sm font-medium text-gray-900">
                Do you have a Meetup account?
              </p>
              <p class="mt-1 text-sm text-gray-700">
                RSVP on Meetup and join the South Florida Actors community. This
                is optional, but we appreciate seeing our community grow!
              </p>

              <a
                id="success-meetup-link"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-flex items-center text-sm font-semibold text-purple hover:underline"
              >
                RSVP on Meetup →
              </a>
            </div>
          </div>
        </div>

        <div
          id="modal-footer"
          class="bg-gray-100 px-6 py-4 flex flex-col-reverse gap-3 sm:flex-row sm:justify-end"
        >
          <button
            id="close-btn"
            type="button"
            class="rounded-md bg-gray-800 px-4 py-2 text-white cursor-pointer"
          >
            Close
          </button>

          <button
            id="submit-registration-btn"
            type="submit"
            class="rounded-md bg-red-400 px-5 py-2 text-white font-semibold hover:bg-purple transition-colors cursor-pointer"
          >
            Submit registration
          </button>
        </div>
      </form>
    </div>
  </div>
</dialog>

<script>
  import { paypalUrl, type TClassListing } from '../data/classes'
  import {
    formatDate,
    formatLongWeekday,
    formatTimeRange,
  } from '../helpers/listingHelpers'

  const modal = document.getElementById(
    'classRegistrationModal'
  ) as HTMLDialogElement
  const modalBackdrop = document.querySelector(
    '[data-modal-backdrop]'
  ) as HTMLElement

  const closeBtn = document.getElementById('close-btn') as HTMLButtonElement
  const submitRegistrationBtn = document.getElementById(
    'submit-registration-btn'
  ) as HTMLButtonElement
  const form = document.getElementById('registration-form') as HTMLFormElement
  const status = document.getElementById('registration-status') as HTMLElement
  const studentFields = document.getElementById('student-fields') as HTMLElement
  const paymentSection = document.getElementById(
    'payment-section'
  ) as HTMLElement
  const paymentSectionHeading = document.getElementById(
    'payment-section-heading'
  ) as HTMLElement
  const zelleOption = document.getElementById('zelle-option') as HTMLElement
  const paypalOption = document.getElementById('paypal-option') as HTMLElement
  const classSummary = document.getElementById('class-summary') as HTMLElement
  const registrationNote = document.getElementById(
    'registration-note'
  ) as HTMLElement
  const modalFooter = document.getElementById('modal-footer') as HTMLElement
  const successPanel = document.getElementById('success-panel') as HTMLElement
  const successClass = document.getElementById('success-class') as HTMLElement
  const successSession = document.getElementById(
    'success-session'
  ) as HTMLElement
  const successMeetupLink = document.getElementById(
    'success-meetup-link'
  ) as HTMLAnchorElement
  const successPaymentInstructions = document.getElementById(
    'success-payment-instructions'
  ) as HTMLElement
  const successPaymentMemo = document.getElementById(
    'success-payment-memo'
  ) as HTMLElement
  const successPaypalLink = document.getElementById(
    'success-paypal-link'
  ) as HTMLAnchorElement

  const classTitleInput = document.getElementById(
    'form-class-title'
  ) as HTMLInputElement
  const sessionDetailsInput = document.getElementById(
    'form-session-details'
  ) as HTMLInputElement
  const paymentNoteInput = document.getElementById(
    'form-payment-note'
  ) as HTMLInputElement

  const summaryTitle = document.getElementById('summary-title') as HTMLElement
  const summaryDate = document.getElementById('summary-date') as HTMLElement
  const summaryPrice = document.getElementById('summary-price') as HTMLElement
  const zelleMemoPreview = document.getElementById(
    'zelle-memo-preview'
  ) as HTMLElement
  const paypalMemoPreview = document.getElementById(
    'paypal-memo-preview'
  ) as HTMLElement
  const paypalLink = document.getElementById('paypal-link') as HTMLAnchorElement
  const paymentMethodInputs = Array.from(
    form.querySelectorAll<HTMLInputElement>('input[data-payment-method]')
  )

  let activeClassData: TClassListing | null = null
  let hasSubmittedSuccessfully = false
  const submitButtonDefaultText = submitRegistrationBtn.textContent || ''

  const getSessionDisplay = (classData: TClassListing) => {
    const formatted = formatDate(classData.date)
    const day = formatLongWeekday(classData.date)

    const timeRange = formatTimeRange(classData.date, classData.endDate)
    const displayDay = classData.type === 'class' ? classData.dayOfWeek : day
    const displayDate = formatted.date.replace(/^[A-Za-z]{3},\s/, '')

    return {
      displayDate,
      displayDay,
      timeRange,
      sessionText: `${displayDay}, ${displayDate} • ${timeRange}`,
    }
  }

  const getPaymentMemo = (classData: TClassListing, studentName: string) => {
    const session = getSessionDisplay(classData)
    return `${classData.title} - ${session.displayDate} - ${studentName}`
  }

  const lockBodyScroll = () => {
    document.body.classList.add('overflow-hidden')
  }

  const unlockBodyScroll = () => {
    document.body.classList.remove('overflow-hidden')
  }

  const setPaymentMethod = (method: string) => {
    paymentMethodInputs.forEach((input) => {
      input.checked = input.dataset.paymentMethod === method
    })
  }

  const getSelectedPaymentMethod = () =>
    paymentMethodInputs.find((input) => input.checked)?.dataset
      .paymentMethod || 'Zelle'

  paymentMethodInputs.forEach((input) => {
    input.addEventListener('change', () => {
      if (input.checked) {
        setPaymentMethod(input.dataset.paymentMethod || 'Zelle')
      }
    })
  })

  window.addEventListener('open-class-modal', (e: Event) => {
    const customEvent = e as CustomEvent<TClassListing>
    const classData = customEvent.detail
    activeClassData = classData
    hasSubmittedSuccessfully = false

    const session = getSessionDisplay(classData)

    summaryTitle.textContent = classData.title
    summaryDate.textContent = session.sessionText
    summaryPrice.textContent = `$${classData.price}`
    zelleMemoPreview.textContent = `${classData.title} - ${session.displayDate} - Your Name`
    paypalMemoPreview.textContent = `${classData.title} - ${session.displayDate} - Your Name`
    paypalLink.href = paypalUrl

    form.reset()
    setPaymentMethod('Zelle')

    classTitleInput.value = classData.title
    sessionDetailsInput.value = session.sessionText
    paymentNoteInput.value = ''

    classSummary.classList.remove('hidden')
    status.classList.add('hidden')
    status.textContent = ''
    successPanel.classList.add('hidden')
    successPaypalLink.classList.add('hidden')
    studentFields.classList.remove('hidden')
    paymentSection.classList.remove('hidden')
    paymentSectionHeading.classList.remove('hidden')
    registrationNote.classList.remove('hidden')
    modalFooter.classList.remove('hidden')
    submitRegistrationBtn.classList.remove('hidden')
    submitRegistrationBtn.disabled = false
    submitRegistrationBtn.textContent = submitButtonDefaultText

    paymentMethodInputs.forEach((input) => {
      input.disabled = false
    })

    zelleOption.classList.remove('hidden')
    paypalOption.classList.remove('hidden')
    modal.showModal()
    lockBodyScroll()
  })

  closeBtn.addEventListener('click', () => {
    modal.close()
  })

  modal.addEventListener('close', () => {
    unlockBodyScroll()
  })

  modalBackdrop.addEventListener('click', (e) => {
    if (
      e.target === modalBackdrop &&
      !submitRegistrationBtn.disabled &&
      !hasSubmittedSuccessfully
    ) {
      modal.close()
    }
  })

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    if (!activeClassData) return

    const paymentMethod = getSelectedPaymentMethod()
    const formData = new FormData(form)
    const studentName = String(formData.get('studentName')).trim()
    const memo = getPaymentMemo(activeClassData, studentName)

    paymentNoteInput.value =
      paymentMethod === 'Zelle'
        ? 'Student plans to pay with Zelle.'
        : 'Student plans to pay with PayPal.'

    const data = new URLSearchParams()
    data.append('form-name', 'registration')

    for (const [key, value] of new FormData(form).entries()) {
      if (typeof value === 'string') {
        data.append(key, value)
      }
    }

    submitRegistrationBtn.disabled = true
    submitRegistrationBtn.textContent = 'Submitting...'
    status.classList.add('hidden')
    status.textContent = ''

    fetch('/', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      body: data.toString(),
    })
      .then((response) => {
        if (!response.ok) {
          throw new Error(`Registration submission failed (${response.status})`)
        }
        const session = getSessionDisplay(activeClassData!)

        classSummary.classList.add('hidden')
        successClass.textContent = activeClassData!.title
        successSession.textContent = session.sessionText
        successMeetupLink.href = activeClassData!.url
        successPaymentInstructions.textContent =
          paymentMethod === 'Zelle'
            ? 'To confirm your spot, send payment by Zelle to sararogers147@gmail.com.'
            : 'To confirm your spot, open PayPal and complete payment.'
        successPaymentMemo.textContent = `Memo: ${memo}`
        successPaypalLink.href = paypalUrl
        successPaypalLink.classList.toggle('hidden', paymentMethod === 'Zelle')

        if (paymentMethod === 'Zelle') {
          paypalOption.classList.add('hidden')
        } else {
          zelleOption.classList.add('hidden')
        }

        studentFields.classList.add('hidden')
        paymentSection.classList.add('hidden')
        paymentSectionHeading.classList.add('hidden')
        registrationNote.classList.add('hidden')
        modalFooter.classList.remove('hidden')
        submitRegistrationBtn.classList.add('hidden')
        submitRegistrationBtn.disabled = false
        submitRegistrationBtn.textContent = submitButtonDefaultText
        status.classList.add('hidden')
        successPanel.classList.remove('hidden')
        hasSubmittedSuccessfully = true

        paymentMethodInputs.forEach((input) => {
          input.disabled = true
        })
      })
      .catch((error) => {
        status.textContent = 'Something went wrong. Please try again.'
        status.className = 'mt-4 text-sm text-center text-red-700'
        submitRegistrationBtn.disabled = false
        submitRegistrationBtn.textContent = submitButtonDefaultText
        console.error(error)
      })
  })
</script>
