---
import type { TClassListing } from '../data/classes'
import { sessions as classSessions } from '../data/classes/sessions'
import { formatDate } from '../helpers/listingHelpers'

const { classData } = Astro.props as { classData: TClassListing }

const sessions = classSessions.filter(
  (session) => session.classSlug === classData.slug
)

const getSessionBadge = (date: string) => {
  const daysUntil = Math.ceil(
    (new Date(date).getTime() - Date.now()) / (1000 * 60 * 60 * 24)
  )

  if (daysUntil <= 0) return 'Past'
  if (daysUntil <= 7) return 'This week'
  if (daysUntil <= 14) return 'Coming up'
  return null
}
---

<div class="mt-8 rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
  {
    sessions.length > 0 ? (
      <>
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500">Price</p>
            <p class="mt-2 text-4xl font-semibold">${classData.price}</p>
          </div>
        </div>

        <div class="mt-8 border-t border-gray-200 pt-6">
          <h2 class="text-lg font-semibold text-purple">Upcoming sessions</h2>

          <div class="mt-4 space-y-3">
            {sessions.map((session) => {
              const formatted = formatDate(session.date)
              const day = new Date(session.date).toLocaleDateString('en-US', {
                weekday: 'long',
              })

              return (
                <div class="rounded-lg border border-gray-200 bg-white p-5 transition hover:border-purple hover:bg-purple/5 hover:shadow-sm">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-2xl font-semibold text-gray-900">
                        {formatted.date.replace(/^[A-Za-z]{3},\s/, '')}
                      </p>

                      <p class="mt-2 text-sm font-medium text-gray-600">
                        {classData.type === 'class' ? classData.dayOfWeek : day}
                        <span class="mx-2 text-gray-400">•</span>
                        {classData.type === 'class'
                          ? '6:30–9:30 PM'
                          : '12–3 PM'}
                      </p>
                    </div>

                    {getSessionBadge(session.date) && (
                      <span class="rounded-full bg-purple/10 px-2 py-1 text-xs font-semibold text-purple whitespace-nowrap">
                        {getSessionBadge(session.date)}
                      </span>
                    )}
                  </div>

                  <div class="mt-5 flex items-center justify-between gap-4 border-t border-gray-100 pt-4">
                    <button
                      type="button"
                      class="rounded-md bg-red-400 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-purple cursor-pointer"
                      data-register-button
                      data-class-title={classData.title}
                      data-class-slug={classData.slug}
                      data-class-type={classData.type}
                      data-class-day-of-week={classData.dayOfWeek}
                      data-session-date={session.date}
                      data-session-url={session.url}
                      data-class-price={classData.price}
                    >
                      Register
                    </button>

                    <a
                      href={session.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm font-semibold text-purple hover:underline"
                    >
                      View on Meetup
                    </a>
                  </div>
                </div>
              )
            })}
          </div>
        </div>
      </>
    ) : (
      <div class="text-center py-6">
        <p class="font-medium text-gray-800">
          No upcoming sessions are currently scheduled.
        </p>

        <p class="mt-2 text-sm text-gray-600">
          Check back soon or contact Sara to be notified about the next
          offering.
        </p>

        <a
          href="/contact"
          class="mt-6 inline-block rounded-md bg-purple px-6 py-3 font-semibold text-white hover:opacity-90 transition"
        >
          Contact Sara
        </a>
      </div>
    )
  }
</div>

<script>
  const registerButtons = document.querySelectorAll<HTMLButtonElement>(
    '[data-register-button]'
  )

  registerButtons.forEach((button) => {
    button.addEventListener('click', () => {
      window.dispatchEvent(
        new CustomEvent('open-class-modal', {
          detail: {
            title: button.dataset.classTitle,
            slug: button.dataset.classSlug,
            type: button.dataset.classType,
            dayOfWeek: button.dataset.classDayOfWeek,
            date: button.dataset.sessionDate,
            url: button.dataset.sessionUrl,
            price: Number(button.dataset.classPrice),
          },
        })
      )
    })
  })
</script>
