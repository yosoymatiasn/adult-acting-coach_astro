---
// ResponsiveHeader.astro
import { navLinks, type NavLink } from '../data/nav'
import Image from 'astro/components/Image.astro'
import logo from '../assets/images/logo.png'
---

<header
  id="site-header"
  class="fixed top-0 z-50 w-full bg-transparent py-4 transition-[padding] duration-300"
>
  <div class="container mx-auto flex items-center justify-between px-4">
    <a
      href="/"
      class="flex h-12 w-12 items-center justify-center rounded-full bg-white p-2 ring-1 ring-purple/15 md:hidden"
    >
      <Image
        src={logo}
        alt="Logo"
        width="56"
        height="56"
        class="h-full w-full object-contain"
        loading="eager"
      />
    </a>

    <!-- Desktop Nav -->
    <nav
      id="desktop-nav"
      class="mx-auto hidden items-center gap-4 rounded-full border border-purple/10 bg-white/95 px-5 py-3 text-purple shadow-lg shadow-purple/10 backdrop-blur-md transition-[padding,box-shadow,background-color] duration-300 md:flex"
    >
      <!-- Logo -->
      <a
        href="/"
        id="desktop-logo-link"
        class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-white p-2 ring-1 ring-purple/15 transition-[width,height,padding,opacity] duration-300 hover:opacity-80 lg:h-16 lg:w-16 lg:p-2.5"
      >
        <Image
          src={logo}
          alt="Logo"
          width="80"
          height="80"
          class="h-full w-full object-contain"
          loading="eager"
        />
      </a>
      <ul class="flex flex-wrap items-center gap-2 lg:gap-3">
        {
          navLinks.map((link: NavLink) => (
            <li>
              <a
                href={link.href}
                class="rounded px-2 py-1 text-base font-semibold transition-colors hover:bg-purple/10 lg:px-3 lg:text-lg"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Hamburger Button -->
    <button
      id="hamburger"
      class="relative z-50 ml-auto flex h-11 w-11 cursor-pointer flex-col items-center justify-center gap-1.5 rounded-md border border-purple/20 bg-white text-purple shadow-sm md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span id="bar1" class="h-0.5 w-6 rounded-sm bg-purple transition-all"
      ></span>
      <span id="bar2" class="h-0.5 w-6 rounded-sm bg-purple transition-all"
      ></span>
      <span id="bar3" class="h-0.5 w-6 rounded-sm bg-purple transition-all"
      ></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="pointer-events-none absolute left-0 top-full z-50 w-full origin-top -translate-y-4 scale-95 transform-gpu px-4 pt-1 text-purple opacity-0 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] will-change-transform motion-reduce:transition-none md:hidden"
    aria-hidden="true"
  >
    <div
      class="mx-auto max-w-md overflow-hidden rounded-b-2xl border border-purple/10 bg-white shadow-xl shadow-purple/10"
    >
      <div class="flex items-center gap-3 border-b border-purple/10 px-5 py-4">
        <span
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white p-2 ring-1 ring-purple/15"
        >
          <Image
            src={logo}
            alt="Sara Rogers logo"
            width="64"
            height="64"
            class="h-full w-full object-contain"
            loading="eager"
          />
        </span>
        <div>
          <p class="text-lg font-bold leading-tight text-purple">Sara Rogers</p>
          <p class="text-sm leading-tight text-gray-600">
            Acting classes and coaching
          </p>
        </div>
      </div>

      <div class="space-y-3 px-5 py-5">
        <a
          href="/classes"
          class="block rounded-md bg-purple px-4 py-3 text-center text-lg font-semibold text-white transition-colors hover:bg-purple-light"
        >
          View Classes
        </a>

        <a
          href="/contact"
          class="block rounded-md border border-purple/25 px-4 py-3 text-center text-lg font-semibold text-purple transition-colors hover:bg-purple/10"
        >
          Contact Sara
        </a>

        <div class="grid grid-cols-2 gap-2 pt-2">
          {
            navLinks
              .filter(
                (link: NavLink) =>
                  !['/', '/classes', '/contact'].includes(link.href)
              )
              .map((link: NavLink) => (
                <a
                  href={link.href}
                  class="rounded-md bg-purple/5 px-3 py-3 text-center text-base font-semibold transition-colors hover:bg-purple/10"
                >
                  {link.label}
                </a>
              ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Toggle Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const hamburger = document.getElementById('hamburger')
      const menu = document.getElementById('mobile-menu')
      const header = document.getElementById('site-header')
      const desktopNav = document.getElementById('desktop-nav')
      const desktopLogoLink = document.getElementById('desktop-logo-link')

      const bar1 = document.getElementById('bar1')
      const bar2 = document.getElementById('bar2')
      const bar3 = document.getElementById('bar3')

      let isOpen = false
      let isScrolled = false

      const setMenuOpen = (nextOpen: boolean) => {
        isOpen = nextOpen
        menu?.classList.toggle('pointer-events-none', !isOpen)
        menu?.classList.toggle('pointer-events-auto', isOpen)
        menu?.classList.toggle('opacity-0', !isOpen)
        menu?.classList.toggle('opacity-100', isOpen)
        menu?.classList.toggle('-translate-y-4', !isOpen)
        menu?.classList.toggle('translate-y-0', isOpen)
        menu?.classList.toggle('scale-95', !isOpen)
        menu?.classList.toggle('scale-100', isOpen)
        menu?.setAttribute('aria-hidden', String(!isOpen))
        hamburger?.setAttribute('aria-expanded', String(isOpen))

        bar1?.classList.toggle('rotate-45', isOpen)
        bar1?.classList.toggle('translate-y-2', isOpen)

        bar2?.classList.toggle('opacity-0', isOpen)

        bar3?.classList.toggle('-rotate-45', isOpen)
        bar3?.classList.toggle('-translate-y-2', isOpen)
      }

      const setScrolled = (nextScrolled: boolean) => {
        if (isScrolled === nextScrolled) return
        isScrolled = nextScrolled

        header?.classList.toggle('md:py-2', isScrolled)

        desktopNav?.classList.toggle('bg-white', isScrolled)
        desktopNav?.classList.toggle('bg-white/95', !isScrolled)
        desktopNav?.classList.toggle('px-4', isScrolled)
        desktopNav?.classList.toggle('py-2', isScrolled)
        desktopNav?.classList.toggle('px-5', !isScrolled)
        desktopNav?.classList.toggle('py-3', !isScrolled)
        desktopNav?.classList.toggle('shadow-xl', isScrolled)
        desktopNav?.classList.toggle('shadow-lg', !isScrolled)

        desktopLogoLink?.classList.toggle('md:h-12', isScrolled)
        desktopLogoLink?.classList.toggle('md:w-12', isScrolled)
        desktopLogoLink?.classList.toggle('md:p-1.5', isScrolled)
        desktopLogoLink?.classList.toggle('lg:h-12', isScrolled)
        desktopLogoLink?.classList.toggle('lg:w-12', isScrolled)
        desktopLogoLink?.classList.toggle('lg:p-1.5', isScrolled)
        desktopLogoLink?.classList.toggle('h-14', !isScrolled)
        desktopLogoLink?.classList.toggle('w-14', !isScrolled)
        desktopLogoLink?.classList.toggle('p-2', !isScrolled)
        desktopLogoLink?.classList.toggle('lg:h-16', !isScrolled)
        desktopLogoLink?.classList.toggle('lg:w-16', !isScrolled)
        desktopLogoLink?.classList.toggle('lg:p-2.5', !isScrolled)
      }

      const handleScroll = () => {
        setScrolled(window.scrollY > 24)
      }

      handleScroll()
      window.addEventListener('scroll', handleScroll, { passive: true })

      // Toggle menu and animate hamburger
      hamburger?.addEventListener('click', () => {
        setMenuOpen(!isOpen)
      })

      menu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          setMenuOpen(false)
        })
      })

      // Reset on desktop resize
      const mediaQuery = window.matchMedia('(min-width: 768px)')
      mediaQuery.addEventListener('change', (e) => {
        if (e.matches) {
          setMenuOpen(false)
        }
      })
    })
  </script>
</header>
