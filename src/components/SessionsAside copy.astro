---
import type { TClassListing } from '../data/classes'
import { sessions as classSessions } from '../data/classes/sessions'
import { formatDate } from '../helpers/listingHelpers'

const { classData } = Astro.props as { classData: TClassListing }

const sessions = classSessions.filter(
  (session) => session.classSlug === classData.slug
)

const getSessionBadge = (date: string) => {
  const daysUntil = Math.ceil(
    (new Date(date).getTime() - Date.now()) / (1000 * 60 * 60 * 24)
  )

  if (daysUntil <= 0) return 'Past'
  if (daysUntil <= 7) return 'This week'
  if (daysUntil <= 14) return 'Coming up'
  return null
}
---

<div class="mt-8 rounded-lg border p-8">
  {
    sessions.length > 0 ? (
      <>
        <p class="text-xs uppercase tracking-wide text-gray-500">Price</p>

        <p class="mt-2 text-4xl font-semibold">${classData.price}</p>

        <button
          type="button"
          class="mt-8 w-full rounded-md bg-red-400 py-4 font-semibold text-white hover:bg-purple transition-colors cursor-pointer"
        >
          Register
        </button>

        <div class="mt-8 border-t pt-6">
          <h2 class="text-lg font-semibold">Upcoming sessions</h2>

          <div class="mt-4 space-y-3">
            {sessions.map((session) => {
              const formatted = formatDate(session.date)
              const day = new Date(session.date).toLocaleDateString('en-US', {
                weekday: 'long',
              })

              return (
                <a
                  href={session.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block rounded-md border p-4 hover:border-purple hover:bg-purple/5 transition"
                >
                  <div class="flex items-start justify-between gap-3">
                    <p class="font-semibold">
                      {formatted.date.replace(/^[A-Za-z]{3},\s/, '')}
                    </p>

                    {getSessionBadge(session.date) && (
                      <span class="rounded-full bg-purple/10 px-2 py-1 text-xs font-semibold text-purple whitespace-nowrap">
                        {getSessionBadge(session.date)}
                      </span>
                    )}
                  </div>

                  <p class="mt-1 text-sm text-gray-600">
                    {classData.type === 'class' ? classData.dayOfWeek : day}
                    <span class="mx-2 text-gray-400">•</span>
                    {classData.type === 'class' ? '6:30–9:30 PM' : '12–3 PM'}
                  </p>
                </a>
              )
            })}
          </div>
        </div>
      </>
    ) : (
      <div class="text-center py-6">
        <p class="font-medium text-gray-800">
          No upcoming sessions are currently scheduled.
        </p>

        <p class="mt-2 text-sm text-gray-600">
          Check back soon or contact Sara to be notified about the next
          offering.
        </p>

        <a
          href="/contact"
          class="mt-6 inline-block rounded-md bg-purple px-6 py-3 font-semibold text-white hover:opacity-90 transition"
        >
          Contact Sara
        </a>
      </div>
    )
  }
</div>
