---
import PageLayout from '../layouts/PageLayout.astro'

import { brandingTestimonials } from '../data/testimonials'
import Carousel from '../components/Carousel.astro'
import YoutubeEmbed from '../components/YoutubeEmbed.astro'
import type { Metadata } from '../utils/seo'
import PageIntro from '../components/PageIntro.astro'

const meta: Metadata = {
  title: 'Building Your Brand | Sara Rogers Acting',
  description:
    'An 8-week private coaching course with Sara Rogers for actors, performers, and models who want to clarify goals, sharpen materials, and build their professional brand.',
  url: 'https://adultactingcoach.com/building-your-brand',
}
---

<PageLayout meta={meta}>
  <div class="mx-auto flex max-w-6xl flex-col">
    <PageIntro
      eyebrow="Private coaching"
      title="Building Your Brand"
      description="An 8-week private coaching course for actors, performers, and models who want to clarify their goals, sharpen their materials, and present themselves with confidence."
    >
      <a href="/contact" class="sr-link inline-block w-auto"> Contact Sara </a>
    </PageIntro>

    <section class="mt-12 grid gap-6 md:grid-cols-[1fr_1fr]">
      <div
        class="rounded-lg border border-purple/10 bg-white p-6 shadow-sm md:p-8"
      >
        <h2 class="text-3xl text-gray-950">A one-on-one plan</h2>
        <p class="mt-4 text-lg leading-8 text-gray-700 md:text-xl">
          Starting on a date you and Sara choose, this 8-week personalized
          course focuses on the business side of acting and modeling, your
          goals, and the materials you need to present yourself well.
        </p>
      </div>

      <div
        class="rounded-lg border border-purple/10 bg-white p-6 shadow-sm md:p-8"
      >
        <h2 class="text-3xl text-gray-950">Who it is for</h2>
        <p class="mt-4 text-lg leading-8 text-gray-700 md:text-xl">
          This course is for performers who want more than a brush-up on skills.
          Whether you are just starting or already working, the goal is to build
          a clear action plan tailored to you.
        </p>
      </div>
    </section>

    <section
      class="mt-12 rounded-lg border border-purple/10 bg-white p-6 md:p-8"
    >
      <h2 class="text-3xl text-gray-950">What you&apos;ll work on</h2>
      <div class="mt-6 grid gap-3 md:grid-cols-2">
        {
          [
            'Discovering your main type',
            'Understanding your unique attributes',
            'Writing an impressive resume',
            'Showcasing your skills',
            'On-camera skills',
            'Self-taping scenes and monologues',
            'Memorization techniques',
            'Headshot guidance',
            'Social media strategy',
            'Agents and casting directors',
            'Set and agent etiquette',
            'Union vs. non-union choices',
            'Industry websites',
          ].map((item) => (
            <p class="rounded-md bg-purple/5 px-4 py-3 text-base font-semibold text-gray-800 md:text-lg">
              {item}
            </p>
          ))
        }
      </div>
    </section>

    <section class="mt-12 grid gap-6 md:grid-cols-[1fr_1fr]">
      <div class="rounded-lg bg-purple p-6 text-white md:p-8">
        <h2 class="text-3xl text-white">Fees and scheduling</h2>
        <div class="mt-4 space-y-4 text-lg leading-8 text-white/90">
          <p>
            <span class="font-bold">Investment:</span> $1200 for the full 8-week
            course, payable upfront.
          </p>
          <p>
            Scheduling is flexible based on Sara&apos;s availability and yours,
            up to two sessions per week. Missed sessions must be rescheduled
            within the 8-week period.
          </p>
        </div>
      </div>

      <div class="rounded-lg border border-purple/15 bg-white p-6 md:p-8">
        <h2 class="text-3xl text-gray-950">Discount opportunity</h2>
        <p class="mt-4 text-lg leading-8 text-gray-700 md:text-xl">
          Participate in the Step One Saturday Workshop and get $100 off. This
          reduces the course to 7 weeks, with your first week covered in the
          3-hour workshop.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-12 w-full max-w-3xl">
      <div class="mb-6 text-center">
        <h2 class="mb-2 text-3xl text-gray-950">Words from students</h2>
        <p class="text-lg leading-8 text-gray-700 md:text-xl">
          Students share their experience with Sara&apos;s one-on-one coaching.
        </p>
      </div>
      <Carousel
        class="mx-auto w-full max-w-3xl"
        label="Student video testimonials"
      >
        {
          brandingTestimonials.map(({ youtubeId }) => (
            <YoutubeEmbed lazy id={youtubeId} />
          ))
        }
      </Carousel>
    </section>

    <section
      class="mt-12 rounded-lg border border-purple/10 bg-white p-6 text-center shadow-sm md:p-8"
    >
      <h2 class="text-3xl text-gray-950">Ready to schedule?</h2>
      <p class="mx-auto max-w-3xl text-lg leading-8 text-gray-700 md:text-xl">
        Payment methods include Zelle, cash, check, and PayPal. To schedule your
        private session or ask for more information, contact Sara.
      </p>
      <a href="/contact" class="sr-link inline-block w-auto">Contact Sara</a>
    </section>
  </div>
</PageLayout>
