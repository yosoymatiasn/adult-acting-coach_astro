---
import ContactForm from '../components/ContactForm.astro'
import PageLayout from '../layouts/PageLayout.astro'
import type { Metadata } from '../utils/seo'
import PageIntro from '../components/PageIntro.astro'

const meta: Metadata = {
  title: 'Contact | Sara Rogers Acting',
  description:
    'Ready to embark on a transformative journey? Reach out to Sara Rogers and take the first step toward unlocking your potential in acting and public speaking.',
  url: 'https://adultactingcoach.com/contact',
}
---

<PageLayout meta={meta}>
  <div class="flex flex-col">
    <PageIntro
      title="Contact Sara"
      description="Questions about classes, private coaching, self-tapes, showcases, or public speaking? Send a note and Sara will follow up."
    />
    <div class="mt-12 max-w-2xl mx-auto w-full">
      <ContactForm />
    </div>
  </div>
</PageLayout>
