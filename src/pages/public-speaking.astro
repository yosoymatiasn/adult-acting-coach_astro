---
import YoutubeEmbed from '../components/YoutubeEmbed.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import type { Metadata } from '../utils/seo'

const meta: Metadata = {
  title: 'Public Speaking | Sara Rogers',
  description:
    'Empower yourself or your team with professional public speaking training. Overcome anxiety, engage audiences, and improve communication skills in 4 weeks.',
  url: 'https://adultactingcoach.com/public-speaking',
}

const programDetails = [
  'On-site training at your business location',
  'Weekly 3-hour sessions for 4 weeks',
  'Alternate training space available when needed',
  'Private one-on-one coaching available upon request',
]

const practiceAreas = [
  'Overcoming public speaking anxiety',
  'Structuring presentations for maximum impact',
  'Using voice, body language, and presence with intention',
  'Engaging and persuading an audience',
  'Memorization techniques for scripted material',
  'Handling Q&A and impromptu speaking situations',
]

const audiences = [
  'Executives and team leaders',
  'Sales teams',
  'Customer-facing employees',
  'Nonprofit and fundraising teams',
  'Professionals preparing for presentations, pitches, or events',
]
---

<BaseLayout meta={meta} title="Public Speaking">
  <div class="mx-auto flex max-w-5xl flex-col gap-14">
    <section class="mx-auto max-w-4xl pt-28 text-center md:pt-36">
      <h1>Public Speaking Training for Teams</h1>
      <p class="mx-auto mt-5 max-w-3xl text-gray-700">
        A 4-week on-site coaching program that helps professionals speak with
        confidence, clarity, and presence in meetings, presentations, pitches,
        and client conversations.
      </p>
      <a href="/contact" class="sr-link inline-block w-auto">
        Contact Sara
      </a>
    </section>

    <section class="grid gap-8 lg:grid-cols-[1fr_1.15fr] lg:items-start">
      <div>
        <h2>Training with an actor&apos;s eye</h2>
        <p class="text-gray-700">
          Sara brings decades of acting, coaching, and performance experience to
          business communication. The program focuses on more than words on a
          page: participants practice voice, presence, timing, body language,
          confidence under pressure, and the ability to connect with a room.
        </p>
      </div>

      <div class="rounded-md border border-purple/20 bg-white p-6 shadow-sm">
        <h2 class="text-xl">How It Works</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {
            programDetails.map((detail) => (
              <li class="rounded-md border border-gray-200 bg-gray-50 p-4 text-lg text-gray-700">
                {detail}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section>
      <div class="text-center">
        <h2>What Your Team Will Practice</h2>
        <p class="mx-auto max-w-3xl text-gray-700">
          Each session is hands-on, supportive, and built around practical
          communication skills your team can use immediately.
        </p>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          practiceAreas.map((area) => (
            <div class="rounded-md border border-gray-200 bg-white p-5 shadow-sm">
              <p class="text-lg font-semibold text-gray-800">{area}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="grid gap-8 lg:grid-cols-2">
      <div class="rounded-md border border-gray-200 bg-white p-6 shadow-sm">
        <h2>Who It&apos;s For</h2>
        <ul class="mt-4 space-y-2">
          {
            audiences.map((audience) => (
              <li class="border-b border-gray-100 pb-2 text-lg text-gray-700 last:border-b-0">
                {audience}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="rounded-md border border-gray-200 bg-white p-6 shadow-sm">
        <h2>Customized for Your Company</h2>
        <p class="text-gray-700">
          Every business has its own audience, goals, and pressure points.
          Sara adapts the training to your industry so the work feels relevant,
          specific, and immediately useful.
        </p>
        <p class="mt-4 text-gray-700">
          Organizations such as Make-A-Wish Foundation have found the program
          valuable across departments, helping professionals communicate with
          confidence in donor conversations, events, and internal meetings.
        </p>
      </div>
    </section>

    <section class="mx-auto w-full max-w-3xl text-center">
      <h2>Testimonials</h2>
      <div class="mt-4 border-4 border-purple bg-white">
        <YoutubeEmbed id="0fKFOy3rNnQ" />
      </div>
    </section>

    <section
      class="rounded-md bg-purple/90 p-8 text-center text-white shadow-lg"
    >
      <h2 class="m-0 text-3xl font-semibold text-white">
        Bring Public Speaking Training to Your Team
      </h2>
      <p class="mx-auto mt-4 max-w-3xl">
        Contact Sara to discuss your team&apos;s goals, scheduling, location,
        and pricing. Additional travel fees may apply beyond 10 miles.
      </p>
      <p class="mt-3">
        Private one-on-one public speaking coaching is also available upon
        request.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-block rounded-md border-2 border-white bg-white px-8 py-3 text-xl font-semibold text-purple transition hover:bg-purple hover:text-white"
      >
        Contact Sara
      </a>
    </section>
  </div>
</BaseLayout>
