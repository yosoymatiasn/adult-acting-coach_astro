---
import PageLayout from '../layouts/PageLayout.astro'
import type { Metadata } from '../utils/seo'
import PageIntro from '../components/PageIntro.astro'

const meta: Metadata = {
  title: 'Self-Tapes | Sara Rogers Acting',
  description:
    'Book a self-tape session with Sara Rogers for audition support, a reader, coaching, playback review, and file submission help.',
  url: 'https://adultactingcoach.com/self-tapes',
}
---

<PageLayout meta={meta}>
  <div class="flex flex-col">
    <PageIntro
      eyebrow="Audition support"
      title="Self-Taping and Submissions"
      description="Book a stress-free self-tape session with Sara as your reader and coach, so you can send in a confident, polished audition."
    />

    <div class="mx-auto mt-12 max-w-6xl">
      <section class="grid items-center gap-8 md:grid-cols-[1fr_1.1fr]">
        <div
          class="flex h-56 overflow-hidden rounded-lg border-2 border-purple"
        >
          <img
            src="https://secure.meetupstatic.com/photos/event/d/d/7/3/event_480416691.webp?w=2048"
            alt="Self-taping setup"
            class="w-1/2 object-cover object-top"
            width="300"
            height="300"
            loading="lazy"
          />
          <img
            src="https://secure.meetupstatic.com/photos/event/4/7/a/9/event_474678345.webp?w=2048"
            alt="Actor preparing a self-tape"
            class="w-1/2 object-cover object-left-top"
            width="300"
            height="300"
            loading="lazy"
          />
        </div>

        <div>
          <h2 class="text-3xl text-gray-950">
            A reader, coach, and playback partner in one session.
          </h2>
          <p class="mt-4 text-lg leading-8 text-gray-700 md:text-xl">
            Self-taping and submissions have become the norm, not the exception.
            Actors are now asked to act, direct themselves, make strong choices,
            and submit clean files quickly.
          </p>
          <p class="mt-4 text-lg leading-8 text-gray-700 md:text-xl">
            With Sara, you get a built-in reader and coach. You tape, watch
            playbacks, choose the right take, label the files, and send them
            electronically.
          </p>
        </div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="rounded-lg border border-purple/10 bg-white p-6 shadow-sm">
          <h3 class="text-2xl text-purple">Stress-free setup</h3>
          <p class="text-base leading-7 text-gray-700 md:text-lg">
            A calm session so you can focus on the audition instead of the
            technology.
          </p>
        </div>
        <div class="rounded-lg border border-purple/10 bg-white p-6 shadow-sm">
          <h3 class="text-2xl text-purple">Playback review</h3>
          <p class="text-base leading-7 text-gray-700 md:text-lg">
            Watch your takes with Sara and choose the audition that best serves
            the work.
          </p>
        </div>
        <div class="rounded-lg border border-purple/10 bg-white p-6 shadow-sm">
          <h3 class="text-2xl text-purple">File help</h3>
          <p class="text-base leading-7 text-gray-700 md:text-lg">
            Files are labeled and sent electronically so your submission is
            ready to go.
          </p>
        </div>
      </section>

      <section class="mt-12 grid gap-6 md:grid-cols-[1fr_1fr]">
        <div class="rounded-lg bg-purple p-6 text-white md:p-8">
          <h2 class="text-3xl text-white">Fees and scheduling</h2>
          <div class="mt-4 space-y-4 text-lg leading-8 text-white/90">
            <p>
              The rate is a flat $75 for the hour. If you have several pages or
              more than one scene, additional time is $37.50 for every 30
              minutes.
            </p>
            <p>1.5 hours is $112.50, and 2 hours is $150.</p>
            <p>
              Payment options include cash, PayPal, credit cards, or checks.
              Cash is preferred and you will receive a receipt.
            </p>
          </div>
        </div>

        <div class="rounded-lg border border-purple/15 bg-white p-6 md:p-8">
          <h2 class="text-3xl text-gray-950">Before you arrive</h2>
          <div class="mt-4 space-y-4 text-lg leading-8 text-gray-700">
            <p>
              Your time begins at the time reserved, so please allow enough time
              for traffic, rehearsal, makeup, and wardrobe changes.
            </p>
            <p>
              If you are memorized and ready to tape, the session usually goes
              smoothly within the hour. If you finish early, you can use the
              time to pick Sara&apos;s brain.
            </p>
          </div>
        </div>
      </section>

      <section
        class="mt-12 rounded-lg border border-purple/10 bg-white p-6 text-center shadow-sm md:p-8"
      >
        <h2 class="text-3xl text-gray-950">Notes</h2>
        <div
          class="mx-auto mt-4 max-w-4xl space-y-4 text-lg leading-8 text-gray-700"
        >
          <p>
            The background is grey. Please avoid logos or anything that draws
            the eye away from your audition. Solid colors are best. No black,
            white, or red.
          </p>
          <p>
            Wear jackets, sweaters, or clothing that supports the character when
            possible. Bring options and let the camera decide.
          </p>
          <p>
            Sara is seasoned and wants you to book the job. Read more from her <a
              href="/testimonials"
              class="text-purple underline">testimonials</a
            > to get a sense of her coaching style and how she works with actors.
          </p>
        </div>
        <a href="/contact" class="sr-link inline-block w-auto">
          Schedule a Self-Tape
        </a>
      </section>
    </div>
  </div>
</PageLayout>
