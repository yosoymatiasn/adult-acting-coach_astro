---
import PageLayout from '../layouts/PageLayout.astro'
import ContactForm from '../components/ContactForm.astro'
import YoutubeEmbed from '../components/YoutubeEmbed.astro'
import Image from 'astro/components/Image.astro'
import logo from '../assets/images/logo.png'
import classImage from '../assets/images/class.jpeg'
import brandingImage from '../assets/images/branding.jpeg'
import groupImage from '../assets/images/group.jpeg'
import publicSpeakingImage from '../assets/images/submissions2.jpeg'
import type { Metadata } from '../utils/seo'

const meta: Metadata = {
  title: 'Sara Rogers Acting',
  description:
    'Unlock your potential with Sara Rogers, a premier acting and public speaking coach in South Florida. Join our year-round adult classes, featuring improvisation, monologues, scenes, and more.',
  url: 'https://adultactingcoach.com',
}
---

<PageLayout meta={meta} contained={false} footerSpacious={false} footerBordered={false}>
  <section class="bg-white">
    <div
      class="h-72 w-full bg-purple bg-[linear-gradient(to_bottom,rgba(127,26,127,0.45),rgba(127,26,127,0.18)),url('../assets/images/group.jpeg')] bg-cover bg-top bg-no-repeat md:h-[500px] md:bg-fixed min-[114rem]:h-[600px] min-[114rem]:bg-position-[center_top_-10rem]"
    >
    </div>

    <div class="relative flex justify-center bg-white px-4">
      <div
        data-home-nameplate
        class="-mt-9 inline-flex items-center gap-4 rounded-full border border-purple/15 bg-white py-3 pl-4 pr-8 text-purple shadow-xl shadow-purple/10 md:-mt-10"
      >
        <span
          class="flex h-14 w-14 items-center justify-center rounded-full bg-white md:h-16 md:w-16"
        >
          <Image
            loading="eager"
            src={logo}
            alt="Sara Rogers logo"
            width={80}
            height={80}
            class="h-full w-full object-contain"
          />
        </span>
        <span class="h-10 w-px bg-purple/20 md:h-12"></span>
        <span class="text-lg font-semibold uppercase tracking-wide md:text-xl">
          Sara Rogers
        </span>
      </div>
    </div>

    <div
      class="mx-auto flex max-w-5xl flex-col items-center px-4 pb-12 pt-10 text-center md:pb-16 md:pt-12"
    >
      <h1
        class="max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl"
      >
        Adult acting, improv, and public speaking coaching.
      </h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-gray-700 md:text-2xl">
        Sara Rogers shares many years of personal experience in the business
        with students who want to study, take risks, and grow in a safe and
        judgment-free environment.
      </p>
      <div
        class="mt-8 flex w-full flex-col justify-center gap-3 sm:w-auto sm:flex-row"
      >
        <a href="/classes" class="sr-link mt-0 w-full max-w-none sm:w-auto">
          View Classes
        </a>
        <a
          href="/contact"
          class="mt-0 w-full max-w-none rounded-md border-4 border-purple px-4 py-4 text-center text-xl font-semibold text-purple transition-colors hover:bg-purple/10 md:px-8 md:text-3xl sm:w-auto"
        >
          Contact Sara
        </a>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 px-4 py-14 md:py-20">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
      <a
        href="/classes"
        class="group overflow-hidden rounded-lg border border-purple/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
      >
        <Image
          src={classImage}
          alt="Students working in acting class"
          class="h-48 w-full object-cover object-center"
          width={640}
          height={420}
        />
        <div class="p-6">
          <h2 class="mb-2 text-2xl text-purple">Classes</h2>
          <p class="text-base leading-7 text-gray-700 md:text-lg">
            Year-round adult classes and workshops in monologues, scenes, cold
            reading, camera work, improvisation, and more.
          </p>
          <p class="mt-4 text-lg font-semibold text-purple">See schedule</p>
        </div>
      </a>

      <a
        href="/building-your-brand"
        class="group overflow-hidden rounded-lg border border-purple/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
      >
        <Image
          src={brandingImage}
          alt="Private coaching and personal brand work"
          class="h-48 w-full object-cover object-center"
          width={640}
          height={420}
        />
        <div class="p-6">
          <h2 class="mb-2 text-2xl text-purple">Building Your Brand</h2>
          <p class="text-base leading-7 text-gray-700 md:text-lg">
            Sara&apos;s 8-week private coaching package for actors, performers,
            and models who want to set goals and create a plan for their work.
          </p>
          <p class="mt-4 text-lg font-semibold text-purple">
            Explore the package
          </p>
        </div>
      </a>

      <a
        href="/public-speaking"
        class="group overflow-hidden rounded-lg border border-purple/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
      >
        <Image
          src={publicSpeakingImage}
          alt="Sara Rogers coaching a student on camera"
          class="h-48 w-full object-cover object-center"
          width={640}
          height={420}
        />
        <div class="p-6">
          <h2 class="mb-2 text-2xl text-purple">Public Speaking</h2>
          <p class="text-base leading-7 text-gray-700 md:text-lg">
            Coaching for individuals and teams who want to speak clearly, feel
            more confident, and bring presence into professional settings.
          </p>
          <p class="mt-4 text-lg font-semibold text-purple">Learn more</p>
        </div>
      </a>
    </div>
  </section>

  <section class="bg-white px-4 py-14 md:py-20">
    <div class="mx-auto grid max-w-6xl items-center gap-10 md:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-purple">
          Meet Sara Rogers
        </p>
        <h2 class="mt-2 text-3xl font-bold text-gray-950 md:text-5xl">
          Sara meets each student where they are.
        </h2>
        <div
          class="mt-5 flex flex-col gap-4 text-lg leading-8 text-gray-700 md:text-xl"
        >
          <p>
            After studying Stanislavsky, Uta Hagen, Stella Adler, Sanford
            Meisner, and Viola Spolin, Sara brings many methods into the room
            and finds what works for each individual student.
          </p>
          <p>
            Once you step into class, you will quickly realize you are not alone
            in your quest. Students work together, support each other, and
            create in a safe place.
          </p>
        </div>

        <div
          class="mt-6 rounded-lg border border-purple/20 bg-purple/5 p-5 text-left"
        >
          <p class="text-sm font-semibold uppercase tracking-wide text-purple">
            Recognition
          </p>
          <p class="mt-2 text-lg leading-7 text-gray-700">
            Sara has been honored with a Lifetime Achievement Award by
            ArtServe, along with other awards celebrating her work in South
            Florida&apos;s arts community.
          </p>
        </div>

        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a href="/about" class="sr-link mt-0 inline-block w-auto">
            About Sara
          </a>
          <a
            href="/testimonials"
            class="mt-0 inline-block w-auto rounded-md border-4 border-purple px-4 py-4 text-center text-xl font-semibold text-purple transition-colors hover:bg-purple/10 md:px-8 md:text-3xl"
          >
            Read testimonials
          </a>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg border-8 border-purple bg-purple">
        <YoutubeEmbed id={'5vBuGrKUNmM'} />
      </div>
    </div>
  </section>

  <section class="border-t border-gray-200 bg-gray-50 px-4 py-14 md:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-purple">
          More ways to work with Sara
        </p>
        <h2 class="mt-2 text-3xl font-bold text-gray-950 md:text-5xl">
          Support beyond weekly class.
        </h2>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-lg border border-purple/10 bg-white p-6 shadow-sm md:p-8">
        <h2 class="text-3xl text-gray-950">Self-Tapes</h2>
        <p class="text-lg leading-8 text-gray-700 md:text-xl">
          Sara offers professional self-taping services for actors who need help
          preparing and recording auditions and submissions.
        </p>
        <a
          href="/self-tapes"
          class="mt-5 inline-block text-xl font-semibold text-purple"
        >
          Self-tape services
        </a>
        </div>

        <div class="rounded-lg border border-purple/10 bg-white p-6 shadow-sm md:p-8">
        <h2 class="text-3xl text-gray-950">Showcases and Community</h2>
        <p class="text-lg leading-8 text-gray-700 md:text-xl">
          Stay connected through Meetup, student showcases, guest classes, and
          occasional audition opportunities when they come Sara&apos;s way.
        </p>
        <div class="mt-5 flex flex-col gap-2 text-xl font-semibold text-purple">
          <a href="/showcases">Student showcases</a>
          <a
            href="https://www.meetup.com/South-Florida-Actors/"
            target="_blank"
            rel="noopener noreferrer"
          >
            South Florida Actors on Meetup
          </a>
        </div>
      </div>
      </div>
    </div>
  </section>

  <section class="bg-purple px-4 py-14 text-white md:py-20">
    <div
      class="mx-auto grid max-w-6xl items-start gap-10 md:grid-cols-[0.9fr_1.1fr]"
    >
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-white/80">
          Get started
        </p>
        <h2 class="mt-2 text-3xl font-bold text-white md:text-5xl">
          Have a question for Sara?
        </h2>
        <p class="mt-5 text-lg leading-8 text-white/90 md:text-xl">
          Reach out for more information on classes, private coaching,
          self-tapes, rates, or scheduling.
        </p>
      </div>

      <ContactForm />
    </div>
  </section>
</PageLayout>
