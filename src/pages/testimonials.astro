---
import { testimonials } from '../data/testimonials'
import PageLayout from '../layouts/PageLayout.astro'
import type { Metadata } from '../utils/seo'
import { testimonialImages } from '../utils/testimonialImageImport'
import Image from 'astro/components/Image.astro'
import PageIntro from '../components/PageIntro.astro'

const [featuredTestimonial, ...moreTestimonials] = testimonials

const meta: Metadata = {
  title: 'Testimonials | Sara Rogers Acting',
  description:
    "Read what actors, performers, and students have shared about Sara Rogers' classes, coaching, and self-tape support.",
  url: 'https://adultactingcoach.com/testimonials',
}
---

<PageLayout meta={meta}>
  <div class="flex flex-col">
    <PageIntro
      eyebrow=""
      title="Testimonials"
      description="Past students and colleagues share their experiences working with Sara."
    />
    <div class="mx-auto mt-12 w-full max-w-6xl">
      <section
        class="grid items-center gap-8 rounded-lg border border-purple/15 bg-white p-6 shadow-lg shadow-purple/10 md:grid-cols-[220px_1fr] md:p-8"
      >
        <Image
          src={testimonialImages[featuredTestimonial.imgSrc]}
          width="220"
          height="220"
          alt={`${featuredTestimonial.name} testimonial`}
          class="mx-auto aspect-square w-40 rounded-md border-2 border-purple object-cover md:w-full"
        />

        <div class="text-center md:text-left">
          <blockquote
            class="mt-3 text-2xl font-light leading-9 text-gray-800 md:text-3xl md:leading-10"
          >
            “{featuredTestimonial.text}”
          </blockquote>
          <p class="mt-5 text-xl font-semibold text-purple">
            {featuredTestimonial.name}
          </p>
        </div>
      </section>

      <section class="mt-10 columns-1 gap-5 md:columns-2">
        {
          moreTestimonials.map(({ name, text, imgSrc }) => (
            <article class="mb-5 break-inside-avoid rounded-lg border border-purple/10 bg-white p-5 shadow-sm shadow-purple/5">
              <div class="flex items-center gap-4">
                <Image
                  src={testimonialImages[imgSrc]}
                  width="96"
                  height="96"
                  alt={`${name} testimonial`}
                  class="aspect-square w-20 rounded-md border border-purple/20 object-cover"
                />
                <p class="text-xl font-semibold text-purple">{name}</p>
              </div>

              <blockquote class="mt-4 text-base leading-8 text-gray-700 md:text-lg">
                “{text}”
              </blockquote>
            </article>
          ))
        }
      </section>

      <section
        class="mt-12 rounded-lg bg-purple px-6 py-8 text-center text-white md:px-10"
      >
        <h2 class="text-3xl text-white">Ready to join a class?</h2>
        <p class="mx-auto max-w-3xl text-lg leading-8 text-white/90 md:text-xl">
          Explore upcoming classes or contact Sara if you are not sure where to
          begin.
        </p>
        <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            href="/classes"
            class="rounded-md border-4 border-white bg-white px-6 py-3 text-xl font-semibold text-purple transition-colors hover:bg-purple/10 hover:text-white"
          >
            View Classes
          </a>
          <a
            href="/contact"
            class="rounded-md border-4 border-white px-6 py-3 text-xl font-semibold text-white transition-colors hover:bg-white hover:text-purple"
          >
            Contact Sara
          </a>
        </div>
      </section>
    </div>
  </div>
</PageLayout>
