---
import RegistrationForm from '../../components/RegistrationForm.astro'
import SessionsAside from '../../components/SessionsAside.astro'
import { classes } from '../../data/classes/classes'
import { sessions as classSessions } from '../../data/classes/sessions'
import PageLayout from '../../layouts/PageLayout.astro'
import Image from 'astro/components/Image.astro'
import { createMetaDescription, type Metadata } from '../../utils/seo'

export async function getStaticPaths() {
  return classes.map((classData) => ({
    params: {
      slug: classData.slug,
    },

    props: {
      classData,
      sessions: classSessions.filter(
        (session) => session.classSlug === classData.slug
      ),
    },
  }))
}

const { classData } = Astro.props

const meta: Metadata = {
  title: `${classData.title} | Sara Rogers Acting`,
  description: createMetaDescription(classData.description),
  url: `https://adultactingcoach.com/classes/${classData.slug}`,
  image: classData.imageUrl,
  imageAlt: classData.title,
}
---

<PageLayout meta={meta}>
  <RegistrationForm />
  <div class="max-w-6xl mx-auto px-6 pb-12 pt-28 md:pt-36">
    <div class="grid lg:grid-cols-[1.2fr_1fr] gap-12 items-start">
      <section>
        <p class="text-sm font-semibold uppercase tracking-widest text-purple">
          {classData.type}
        </p>
        <h1 class="mt-2">{classData.title}</h1>

        <p class="mt-8 text-xl leading-9 text-gray-700">
          {classData.description}
        </p>

        <!-- <section class="mt-12">
          <h2>What you'll learn</h2>
          <ul class="mt-4 list-disc space-y-2 pl-6">
            <li>Personalized coaching</li>
            <li>Hands-on exercises</li>
            <li>Professional feedback</li>
            <li>Practical techniques you can immediately apply.</li>
          </ul>
        </section> -->
      </section>

      <aside class="lg:sticky lg:top-24">
        <Image
          src={classData.imageUrl}
          alt={classData.title}
          width={900}
          height={600}
          class="w-full rounded-lg object-cover shadow-lg"
        />

        <SessionsAside classData={classData} />
      </aside>
    </div>
  </div>
</PageLayout>
