---
export const prerender = false

import PageLayout from '../layouts/PageLayout.astro'
import ShowList from '../components/ShowList.astro'
import type { Metadata } from '../utils/seo'
import PageIntro from '../components/PageIntro.astro'

const meta: Metadata = {
  title: 'Showcases | Sara Rogers Acting',
  description:
    'Attend a show curated by Sara and her students. Support actors in the South Florida community as they work on their craft.',
  url: 'https://adultactingcoach.com/showcases',
}
---

<PageLayout meta={meta}>
  <PageIntro
    eyebrow="Student performances"
    title="Showcases"
    description="Support Sara's students as they bring monologues, scenes, improv, and class work to an audience."
  />

  <div
    class="mt-12 grid md:grid-cols-2 items-start gap-y-2 md:gap-x-4 lg:gap-x-6 md:gap-y-3 lg:gap-y-6 md:auto-rows-fr"
  >
    <ShowList />
  </div>

  <section
    class="mx-auto mt-12 max-w-4xl rounded-lg bg-purple px-6 py-8 text-center text-white"
  >
    <h2 class="text-3xl text-white">Want event reminders?</h2>
    <p class="mx-auto max-w-2xl text-lg leading-8 text-white/90 md:text-xl">
      Join the South Florida Actors Meetup group for showcase announcements,
      guest classes, and community updates.
    </p>
    <a
      href="https://www.meetup.com/South-Florida-Actors/"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-block rounded-md border-4 border-white bg-white px-6 py-3 text-xl font-semibold text-purple transition-colors hover:bg-purple hover:text-white"
    >
      View Meetup
    </a>
  </section>
</PageLayout>
