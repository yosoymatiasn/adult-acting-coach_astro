---
import Image from 'astro/components/Image.astro'
import YoutubeEmbed from '../components/YoutubeEmbed.astro'
import PageLayout from '../layouts/PageLayout.astro'
import Sara from '../assets/images/sara.png'
import type { Metadata } from '../utils/seo'

const externalLinks = [
  {
    url: 'https://voyagemia.com/interview/check-out-sara-rogerss-story/',
    title: "Sara Rogers' Story",
    description: 'Enjoy this article on Sara from Voyage Miami',
  },
]

const meta: Metadata = {
  title: 'About | Sara Rogers Acting',
  description:
    'Learn more about Sara Rogers, your dedicated acting coach. With a passion for bringing out the best in performers, Sara is your guide to excellence in acting and public speaking.',
  url: 'https://adultactingcoach.com/about',
}
---

<PageLayout meta={meta}>
  <section class="max-w-4xl mx-auto flex flex-col">
    <section
      class="grid gap-8 pt-28 md:grid-cols-[0.8fr_1.2fr] md:items-center md:pt-36"
    >
      <Image
        src={Sara}
        alt="Sara Rogers"
        class="mx-auto aspect-square w-full max-w-72 rounded-full border-4 border-purple object-cover shadow-lg shadow-purple/20"
        width="320"
        height="320"
      />
      <div class="text-center md:text-left">
        <h1>Sara Rogers</h1>
        <p class="mt-4 text-gray-700">
          Acting coach, public speaking coach, mentor, performer, and longtime
          creative force in South Florida&apos;s film and stage community.
        </p>
      </div>
    </section>

    <section class="mt-12 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-purple/15 bg-purple/5 p-5">
        <p class="text-3xl font-semibold text-purple">40+</p>
        <p
          class="mt-2 text-sm font-semibold uppercase tracking-wide text-gray-600"
        >
          Years of experience
        </p>
      </div>
      <div class="rounded-lg border border-purple/15 bg-purple/5 p-5">
        <p class="text-3xl font-semibold text-purple">Acting</p>
        <p
          class="mt-2 text-sm font-semibold uppercase tracking-wide text-gray-600"
        >
          Scene study, monologues, on-camera work, improv
        </p>
      </div>
      <div class="rounded-lg border border-purple/15 bg-purple/5 p-5">
        <p class="text-3xl font-semibold text-purple">ArtServe</p>
        <p
          class="mt-2 text-sm font-semibold uppercase tracking-wide text-gray-600"
        >
          Lifetime Achievement Honoree
        </p>
      </div>
    </section>

    <article class="mt-12 space-y-10 font-light">
      <section>
        <h2>Teaching & coaching</h2>
        <div class="mt-4 space-y-5">
          <p>
            Sara Rogers has worked in the South Florida film and stage industry
            for over 40 years as a teacher, coach, casting assistant, writer,
            talent coordinator, performer, and voice-over artist.
          </p>
          <p>
            She has taught monologue, scene study, improvisation, camera
            technique, public speaking, and the business side of acting and
            modeling. Her classes are designed to help students build skill,
            confidence, and a clear understanding of how the industry works.
          </p>
          <p>
            Sara has served as a guest teacher at the ACT Symposium and for The
            Lesbian Thesbian. She has also worked as a Public Speaking Coach for
            the Make A Wish Foundation and as a Guest Coach for Women in
            Distress.
          </p>
        </div>
      </section>

      <section>
        <h2>Classes & programs</h2>
        <div class="mt-4 space-y-5">
          <p>
            Sara has crafted unique educational programs that bridge the gap
            between aspiring actors and the industry. "Step One-The Business End
            of the Acting Modeling Business" offers newcomers invaluable
            insights into navigating the industry with a business mindset.
            Meanwhile, "How To Audition For Camera" delves into advanced camera
            techniques, enriching actors' on-screen presence and skills.
          </p>
          <p>
            She taught at Hollywood Playhouse, where she created monologue,
            scene study, and improvisation classes for beginning through
            advanced students. She also taught for 6 ½ years at The Acting
            School of South Florida and has led guest workshops on improvisation
            and acting in corporate settings.
          </p>
        </div>
      </section>

      <section>
        <h2>Casting, performance & voice work</h2>
        <div class="mt-4 space-y-5">
          <p>
            Sara has worked alongside New York casting director Louis DiGiamo
            and local casting professionals including Dee Miller, Kim Houston,
            Ellen Jacoby, Lori Wyman, and Unique Casting. Her casting experience
            includes commercial work for Bacardi Rum, Crest, Publix, Nextel, and
            Hertz.
          </p>
          <p>
            As a voice-over artist, she has worked with Broadcast Video, The
            Miami Herald, NBC local channel 4, The Puppet Theatre, and the New
            York production of “Leaf Meafs.” Her television appearances include
            Extra Large, 21 Jump Street, and Miami Vice, with writing
            contributions to Don Beret-Broadcast Video, Stage and Screen
            Newspaper, and Marquee Magazine.
          </p>
        </div>
      </section>

      <section>
        <h2>At ArtServe</h2>
        <p class="mt-4">
          Sara has brought her teaching style to ArtServe through weekly classes
          that challenge and encourage actors. Her work continues to support a
          safe, secure, and dynamic learning environment for students in South
          Florida.
        </p>
      </section>
    </article>

    <section
      class="mt-14 rounded-lg border border-purple/20 bg-white p-8 text-center shadow-lg shadow-purple/10"
    >
      <p class="text-sm font-semibold uppercase tracking-wide text-purple">
        Awards & Recognition
      </p>

      <h2 class="mt-2">Recognized for a lifetime of artistic impact</h2>

      <div class="mx-auto mt-6 max-w-3xl text-gray-700">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-6">
          <p
            class="text-sm font-semibold uppercase tracking-wide text-gray-500"
          >
            April 17, 2026
          </p>

          <h3 class="mt-2 text-xl font-semibold text-gray-900">
            ArtServe Impact Awards
          </h3>

          <p class="mt-1 font-medium text-purple">
            Lifetime Achievement Honoree
          </p>

          <p class="mt-4">
            Sara Rogers was honored as a <strong
              >Lifetime Achievement Honoree</strong
            >
            at the 2026 ArtServe Impact Awards Gala for her decades of work in South
            Florida's performing arts community as an acting coach, performer, mentor,
            and educator.
          </p>
        </div>
      </div>
    </section>

    <section
      class="mt-14 rounded-lg border border-gray-200 bg-white p-8 shadow-lg shadow-purple/10"
    >
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-purple">
          Media & Press
        </p>
        <h2 class="mt-2">Interviews & features</h2>
        <p class="mx-auto mt-3 max-w-2xl text-sm text-gray-600">
          Hear Sara discuss her coaching journey and work with actors in South
          Florida.
        </p>
      </div>

      <div
        class="mt-8 overflow-hidden rounded-lg border border-gray-200 bg-gray-50"
      >
        <div class="border-b border-gray-200 bg-white px-5 py-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-gray-500"
          >
            Featured Interview
          </p>
          <h3 class="mt-1 text-xl font-semibold text-gray-900">
            Spotlight of the Arts
          </h3>
        </div>

        <div class="p-4">
          <YoutubeEmbed id="gdB8MKam9Kg" />
        </div>
      </div>

      <div class="mt-8">
        <h3 class="text-lg font-semibold text-gray-900">Featured Articles</h3>

        <div class="mt-4 grid gap-4">
          {
            externalLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block rounded-lg border border-gray-200 bg-gray-50 p-5 transition hover:border-purple hover:bg-purple/5"
              >
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
                  Article
                </p>
                <h4 class="mt-1 text-lg font-semibold text-gray-900">
                  {link.title}
                </h4>
                <p class="mt-2 text-sm text-gray-600">{link.description}</p>
                <p class="mt-3 text-sm font-semibold text-purple">
                  Read article →
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </section>
</PageLayout>
